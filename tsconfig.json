{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/api/*": [
        "./src/server/api/*"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "types": [
      "node"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "app/**/*.ts",
    "app/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "src/App.tsx",
    "src/main.tsx",
    "src/entry-server.tsx",
    "src/routes.tsx",
    "src/router-hooks.ts",
    "src/server/entry.ts",
    "src/server/auth-middleware.ts",
    "src/server/api/**/*",
    "src/server/db/client.ts",
    "src/server/db/config.ts",
    "src/server/db/schema.ts",
    "src/lib/auth/auth.ts",
    "src/lib/auth/express-adapter.ts"
  ]
}
